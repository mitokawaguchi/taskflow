# =============================================================================
# TaskFlow — 環境変数（Vite は VITE_ プレフィックス付きのみクライアントに渡す）
# =============================================================================
# コピー: cp .env.example .env のうえで値を編集してください。
# 本番（Vercel 等）ではダッシュボードの環境変数に同じキーを設定すること。
# =============================================================================

# Supabase（必須）
# 取得: https://app.supabase.com → プロジェクト選択 → Settings → API
# Project URL と anon public key をコピー。RLS を有効にしないと他ユーザーデータが参照・改ざん可能になる。
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Gmail OAuth（未返信メールトラッカー用・任意）
# Google Cloud Console で OAuth クライアント（Web）を作成し、承認済みリダイレクト URI に
# 例: https://your-app.vercel.app/mail-tracker または http://localhost:5173/mail-tracker
# VITE_GOOGLE_CLIENT_ID=
# VITE_GOOGLE_REDIRECT_URI=

# -----------------------------------------------------------------------------
# 公開デモ用（GitHub About に載せる URL 用）
# -----------------------------------------------------------------------------
# `true` のときログイン・新規登録画面を出さず、閲覧用メッセージのみ表示する。
# 業務で使うデプロイでは未設定または false にすること。
# VITE_PUBLIC_DEMO_MODE=false
# デモページの「ソースコード」ボタン用（任意）
# VITE_PUBLIC_REPO_URL=https://github.com/yourname/your-repo

# Chatwork（Edge Function send-reminders / fetch-chatwork-unread の Secrets。Vite には載せない）
# CHATWORK_API_TOKEN=
# CHATWORK_MY_ROOM_ID=
# 自分の Chatwork アカウント ID（プロフィール URL の aid 等で確認）。未返信 To 判定に使用
# CHATWORK_MY_ACCOUNT_ID=
# REMINDER_CRON_SECRET=
# REMINDER_OWNER_ID=
